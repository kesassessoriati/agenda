generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformRole {
  USER
  SUPERADMIN
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum CompanyPlan {
  FREE
  BASIC
  PREMIUM
}

enum ScheduleUserRole {
  OWNER
  EDITOR
  VIEWER
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Company {
  id            String                      @id @default(cuid())
  name          String
  slug          String                      @unique
  timezone      String                      @default("America/Sao_Paulo")
  plan          CompanyPlan                 @default(FREE)
  memberships   Membership[]
  invitations   CompanyInvitation[]
  schedules     Schedule[]
  appointments  Appointment[]
  integrations  GoogleCalendarIntegration[]
  workingHours  WorkingHours[]
  auditLogs     AuditLog[]
  scheduleUsers ScheduleUser[]
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt
}

model User {
  id                  String              @id @default(cuid())
  name                String
  email               String              @unique
  passwordHash        String
  platformRole        PlatformRole        @default(USER)
  active              Boolean             @default(true)
  color               String?
  timezone            String              @default("America/Sao_Paulo")
  memberships         Membership[]
  invitedMemberships  Membership[]        @relation("MembershipInvitedBy")
  sentInvitations     CompanyInvitation[] @relation("InvitationInvitedBy")
  acceptedInvitations CompanyInvitation[] @relation("InvitationAcceptedBy")
  ownedSchedules      Schedule[]          @relation("ScheduleOwner")
  scheduleMemberships ScheduleUser[]
  createdAppointments Appointment[]       @relation("AppointmentCreatedBy")
  updatedAppointments Appointment[]       @relation("AppointmentUpdatedBy")
  auditLogs           AuditLog[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model Membership {
  id             String         @id @default(cuid())
  companyId      String
  userId         String
  role           MembershipRole @default(MEMBER)
  active         Boolean        @default(true)
  invitedById    String?
  joinedAt       DateTime       @default(now())
  lastAccessedAt DateTime?
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy      User?          @relation("MembershipInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([companyId, userId])
  @@index([userId, active])
  @@index([companyId, role, active])
}

model CompanyInvitation {
  id               String         @id @default(cuid())
  companyId        String
  email            String
  role             MembershipRole @default(MEMBER)
  tokenHash        String         @unique
  invitedById      String
  acceptedByUserId String?
  expiresAt        DateTime
  acceptedAt       DateTime?
  revokedAt        DateTime?
  company          Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedBy        User           @relation("InvitationInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedByUser   User?          @relation("InvitationAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([companyId, email, expiresAt])
  @@index([companyId, revokedAt, acceptedAt])
}

model Schedule {
  id                        String                     @id @default(cuid())
  companyId                 String
  ownerId                   String
  name                      String
  description               String?
  active                    Boolean                    @default(true)
  color                     String                     @default("#2563eb")
  timezone                  String                     @default("America/Sao_Paulo")
  company                   Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  owner                     User                       @relation("ScheduleOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  assignments               ScheduleUser[]
  appointments              Appointment[]
  workingHours              WorkingHours[]
  googleCalendarIntegration GoogleCalendarIntegration?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  @@index([companyId, active])
}

model ScheduleUser {
  id         String           @id @default(cuid())
  companyId  String
  scheduleId String
  userId     String
  role       ScheduleUserRole @default(EDITOR)
  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  schedule   Schedule         @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([scheduleId, userId])
  @@index([companyId, userId])
}

model WorkingHours {
  id         String   @id @default(cuid())
  companyId  String
  scheduleId String
  dayOfWeek  Int
  startTime  String
  endTime    String
  breakStart String?
  breakEnd   String?
  active     Boolean  @default(true)
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([scheduleId, dayOfWeek])
  @@index([companyId, scheduleId])
}

model GoogleCalendarIntegration {
  id           String    @id @default(cuid())
  companyId    String
  scheduleId   String    @unique
  provider     String    @default("google")
  calendarId   String    @default("primary")
  email        String
  accessToken  String
  refreshToken String?
  tokenExpiry  DateTime?
  syncToken    String?
  lastSyncedAt DateTime?
  active       Boolean   @default(true)
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  schedule     Schedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([companyId, active])
}

model Appointment {
  id                String            @id @default(cuid())
  companyId         String
  scheduleId        String
  title             String
  description       String?
  startAt           DateTime
  endAt             DateTime
  durationMinutes   Int
  status            AppointmentStatus @default(SCHEDULED)
  serviceName       String?
  customerName      String?
  customerEmail     String?
  organizerEmail    String?
  participantEmails String[]
  meetingLink       String?
  externalEventId   String?
  externalProvider  String?
  notes             String?
  createdById       String
  updatedById       String?
  company           Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  schedule          Schedule          @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  createdBy         User              @relation("AppointmentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy         User?             @relation("AppointmentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([companyId, scheduleId, startAt])
  @@index([companyId, status, startAt])
  @@index([companyId, externalEventId])
}

model AuditLog {
  id         String   @id @default(cuid())
  companyId  String
  actorId    String?
  action     String
  entityType String
  entityId   String
  payload    Json?
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([companyId, entityType, entityId])
}
