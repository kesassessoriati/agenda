generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
}

enum ScheduleUserRole {
  OWNER
  EDITOR
  VIEWER
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Company {
  id            String                      @id @default(cuid())
  name          String
  slug          String                      @unique
  timezone      String                      @default("America/Sao_Paulo")
  users         User[]
  schedules     Schedule[]
  appointments  Appointment[]
  integrations  GoogleCalendarIntegration[]
  workingHours  WorkingHours[]
  auditLogs     AuditLog[]
  scheduleUsers ScheduleUser[]
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt
}

model User {
  id                  String         @id @default(cuid())
  companyId           String
  name                String
  email               String         @unique
  passwordHash        String
  role                UserRole       @default(MEMBER)
  active              Boolean        @default(true)
  color               String?
  timezone            String         @default("America/Sao_Paulo")
  company             Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ownedSchedules      Schedule[]     @relation("ScheduleOwner")
  scheduleMemberships ScheduleUser[]
  createdAppointments Appointment[]  @relation("AppointmentCreatedBy")
  updatedAppointments Appointment[]  @relation("AppointmentUpdatedBy")
  auditLogs           AuditLog[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([companyId, role])
}

model Schedule {
  id                        String                     @id @default(cuid())
  companyId                 String
  ownerId                   String
  name                      String
  description               String?
  active                    Boolean                    @default(true)
  color                     String                     @default("#2563eb")
  timezone                  String                     @default("America/Sao_Paulo")
  company                   Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  owner                     User                       @relation("ScheduleOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  assignments               ScheduleUser[]
  appointments              Appointment[]
  workingHours              WorkingHours[]
  googleCalendarIntegration GoogleCalendarIntegration?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  @@index([companyId, active])
}

model ScheduleUser {
  id         String           @id @default(cuid())
  companyId  String
  scheduleId String
  userId     String
  role       ScheduleUserRole @default(EDITOR)
  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  schedule   Schedule         @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([scheduleId, userId])
  @@index([companyId, userId])
}

model WorkingHours {
  id         String   @id @default(cuid())
  companyId  String
  scheduleId String
  dayOfWeek  Int
  startTime  String
  endTime    String
  breakStart String?
  breakEnd   String?
  active     Boolean  @default(true)
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([scheduleId, dayOfWeek])
  @@index([companyId, scheduleId])
}

model GoogleCalendarIntegration {
  id           String    @id @default(cuid())
  companyId    String
  scheduleId   String    @unique
  provider     String    @default("google")
  calendarId   String    @default("primary")
  email        String
  accessToken  String
  refreshToken String?
  tokenExpiry  DateTime?
  syncToken    String?
  lastSyncedAt DateTime?
  active       Boolean   @default(true)
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  schedule     Schedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([companyId, active])
}

model Appointment {
  id                String            @id @default(cuid())
  companyId         String
  scheduleId        String
  title             String
  description       String?
  startAt           DateTime
  endAt             DateTime
  durationMinutes   Int
  status            AppointmentStatus @default(SCHEDULED)
  serviceName       String?
  customerName      String?
  customerEmail     String?
  organizerEmail    String?
  participantEmails String[]
  meetingLink       String?
  externalEventId   String?
  externalProvider  String?
  notes             String?
  createdById       String
  updatedById       String?
  company           Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  schedule          Schedule          @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  createdBy         User              @relation("AppointmentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy         User?             @relation("AppointmentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([companyId, scheduleId, startAt])
  @@index([companyId, status, startAt])
  @@index([companyId, externalEventId])
}

model AuditLog {
  id         String   @id @default(cuid())
  companyId  String
  actorId    String?
  action     String
  entityType String
  entityId   String
  payload    Json?
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([companyId, entityType, entityId])
}
